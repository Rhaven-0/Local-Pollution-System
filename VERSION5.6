// =============================================
// Tab switching
// =============================================
function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
    if (name === 'map') initMap();
}

if (window.location.hash === '#forum') {
    document.getElementById('forum-tab-btn').click();
}

// =============================================
// AJAX Auto-refresh for Dashboard (Section 2 from PDF)
// =============================================
let refreshInterval;

function startAutoRefresh() {
    // Refresh every 30 seconds
    refreshInterval = setInterval(() => {
        if (document.getElementById('tab-dashboard').classList.contains('active')) {
            refreshDashboardData();
        }
    }, 30000);
}

function refreshDashboardData() {
    fetch('dashboard_data.php')
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Update recent reports
                updateRecentReports(data.recent_reports);
                
                // Update nearby incidents
                updateNearbyIncidents(data.nearby_incidents);
                
                // Update notification count
                updateNotificationBadge(data.unread_count);
                
                // Update timestamp
                document.getElementById('update-time').textContent = 'just now';
            }
        })
        .catch(err => console.error('Auto-refresh failed:', err));
}

function updateRecentReports(reports) {
    const tbody = document.getElementById('recent-reports-body');
    if (reports.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted" style="padding:20px;">No reports yet.</td></tr>';
        return;
    }
    
    tbody.innerHTML = reports.map(r => `
        <tr>
            <td>${escapeHtml(r.title)}</td>
            <td>${escapeHtml(r.pollution_type)}</td>
            <td><span style="color:${r.severity_level === 'High' ? '#c0392b' : (r.severity_level === 'Medium' ? '#e0a800' : '#28a745')}">${r.severity_level}</span></td>
            <td><span class="badge badge-${r.status}">${r.status.replace('_', ' ')}</span></td>
            <td>${new Date(r.created_at).toLocaleDateString('en-US', {month: 'short', day: 'numeric', year: 'numeric'})}</td>
        </tr>
    `).join('');
}

function updateNearbyIncidents(incidents) {
    document.getElementById('nearby-count').textContent = incidents.length;
    // Similar implementation for nearby incidents
}

function updateNotificationBadge(count) {
    const bell = document.getElementById('notif-bell');
    const existing = bell.querySelector('.notification-badge');
    if (count > 0) {
        if (existing) {
            existing.textContent = count;
        } else {
            bell.innerHTML += `<span class="notification-badge">${count}</span>`;
        }
    } else {
        if (existing) existing.remove();
    }
}

// Start auto-refresh on page load
window.addEventListener('load', startAutoRefresh);

// =============================================
// AJAX Auto-refresh for Community Feed (Section 4 from PDF)
// =============================================
let feedCountdown = 30;
let feedRefreshTimer;
let feedCountdownTimer;

function startFeedAutoRefresh() {
    feedRefreshTimer = setInterval(() => {
        if (document.getElementById('tab-feed').classList.contains('active')) {
            refreshCommunityFeed();
        }
    }, 30000);
    
    feedCountdownTimer = setInterval(() => {
        feedCountdown--;
        const countdownElem = document.getElementById('feed-countdown');
        if (countdownElem) countdownElem.textContent = feedCountdown;
        if (feedCountdown <= 0) feedCountdown = 30;
    }, 1000);
}

function refreshCommunityFeed() {
    fetch('community_feed_data.php')
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                updateCommunityFeedDisplay(data.approved_reports);
                const timeElem = document.getElementById('feed-update-time');
                if (timeElem) timeElem.textContent = 'just now';
                feedCountdown = 30;
            }
        })
        .catch(err => console.error('Community Feed refresh failed:', err));
}

function updateCommunityFeedDisplay(reports) {
    const container = document.getElementById('community-feed-container');
    const existingIds = Array.from(container.querySelectorAll('.feed-card')).map(card => card.dataset.reportId);
    
    if (reports.length === 0) {
        container.innerHTML = '<p class="text-muted">No approved reports yet.</p>';
        return;
    }
    
    let html = '';
    reports.forEach(r => {
        const isNew = !existingIds.includes(r.id.toString());
        const severityBg = r.severity_level === 'High' ? '#c0392b' : (r.severity_level === 'Medium' ? '#e0a800' : '#28a745');
        const photoHTML = r.photo ? `<img src="uploads/${escapeHtml(r.photo)}" alt="report photo">` : '';
        const descHTML = r.description ? `<div class="feed-desc">${escapeHtml(r.description).replace(/\n/g, '<br>')}</div>` : '';
        const locationHTML = r.location ? `&nbsp;·&nbsp; 📍 ${escapeHtml(r.location)}` : '';
        
        html += `
        <div class="feed-card ${isNew ? 'new-report-flash' : ''}" data-report-id="${r.id}">
            <div class="meta">
                Posted by <strong>${escapeHtml(r.username)}</strong>
                &nbsp;·&nbsp; ${new Date(r.created_at).toLocaleDateString('en-US', {month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit'})}
                ${locationHTML}
            </div>
            <div class="feed-title">${escapeHtml(r.title)}</div>
            <div style="margin:6px 0;">
                <span class="badge" style="background:${severityBg}; color:white;">
                    ${escapeHtml(r.pollution_type)} - ${escapeHtml(r.severity_level)}
                </span>
            </div>
            ${descHTML}
            ${photoHTML}
            <div style="margin-top:10px;">
                <button class="support-btn ${r.user_supported ? 'active' : ''}" 
                        onclick="toggleSupport(${r.id}, this)">
                    👍 <span class="support-count">${r.support_count || 0}</span> Support
                </button>
            </div>
        </div>`;
    });
    
    container.innerHTML = html;
}

// Start Community Feed auto-refresh on load
window.addEventListener('load', startFeedAutoRefresh);

// =============================================
// Notifications
// =============================================
function toggleNotifications() {
    const dropdown = document.getElementById('notification-dropdown');
    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
}

function markRead(notifId) {
    fetch('mark_read.php', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'notif_id=' + notifId
    }).then(() => location.reload());
}

function markAllRead() {
    fetch('mark_read.php', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'notif_id=0'
    }).then(() => location.reload());
}

// Close notifications when clicking outside
document.addEventListener('click', function(e) {
    const dropdown = document.getElementById('notification-dropdown');
    const bell = document.getElementById('notif-bell');
    if (!dropdown.contains(e.target) && !bell.contains(e.target)) {
        dropdown.style.display = 'none';
    }
});

