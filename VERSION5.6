require 'config.php';
redirectIfNotLoggedIn();
redirectIfNotAdmin();

$admin_username = $_SESSION['username'];

// Handle user deletion
if (isset($_GET['delete_user'])) {
    $user_id = (int) $_GET['delete_user'];
    $admin_id = $_SESSION['user_id'];
    
    // Don't allow deleting yourself
    if ($user_id === $admin_id) {
        header("Location: adminDashboard.php?error=cannot_delete_self");
        exit();
    }
    
    // Check if user exists and is not admin
    $check_stmt = $conn->prepare("SELECT role FROM users WHERE id = :id");
    $check_stmt->execute([':id' => $user_id]);
    $user = $check_stmt->fetch();
    
    if ($user && $user['role'] !== 'admin') {
        // Log the deletion
        $log_stmt = $conn->prepare("
            INSERT INTO admin_logs (admin_id, action, notes)
            VALUES (:admin_id, 'user_deleted', CONCAT('Deleted user ID: ', :user_id))
        ");
        $log_stmt->execute([':admin_id' => $admin_id, ':user_id' => $user_id]);
        
        // Delete user (CASCADE will delete related data)
        $stmt = $conn->prepare("DELETE FROM users WHERE id = :id");
        $stmt->execute([':id' => $user_id]);
        
        header("Location: adminDashboard.php?success=user_deleted");
        exit();
    } else {
        header("Location: adminDashboard.php?error=cannot_delete_admin");
        exit();
    }
}

// Handle APPROVAL
if (isset($_POST['approve_report'])) {
    $report_id = (int) $_POST['report_id'];
    $admin_id = $_SESSION['user_id'];
    $approval_notes = isset($_POST['admin_notes']) ? trim($_POST['admin_notes']) : '';
    
    $old_stmt = $conn->prepare("SELECT status, user_id FROM reports WHERE id = :id");
    $old_stmt->execute([':id' => $report_id]);
    $report_info = $old_stmt->fetch();
    
    $upd_stmt = $conn->prepare("
        UPDATE reports 
        SET status = 'approved', is_verified = 1, verified_at = NOW(), verified_by = :aid, admin_notes = :notes
        WHERE id = :id
    ");
    $upd_stmt->execute([':aid' => $admin_id, ':id' => $report_id, ':notes' => $approval_notes]);
    
    $log_stmt = $conn->prepare("
        INSERT INTO admin_logs (admin_id, report_id, action, old_status, new_status, notes)
        VALUES (:admin_id, :report_id, 'approved', :old_status, 'approved', :notes)
    ");
    $log_stmt->execute([
        ':admin_id' => $admin_id,
        ':report_id' => $report_id,
        ':old_status' => $report_info['status'],
        ':notes' => 'Report approved' . ($approval_notes ? ': ' . $approval_notes : '')
    ]);
    
    $notif_stmt = $conn->prepare("
        INSERT INTO notifications (user_id, report_id, type, title, message)
        VALUES (:uid, :rid, 'admin_action', 'Report Approved', 'Your report has been verified and approved')
    ");
    $notif_stmt->execute([':uid' => $report_info['user_id'], ':rid' => $report_id]);
    
    header("Location: adminDashboard.php");
    exit();
}

// Handle REJECTION
if (isset($_POST['reject_report'])) {
    $report_id = (int) $_POST['report_id'];
    $admin_id = $_SESSION['user_id'];
    $rejection_notes = isset($_POST['admin_notes']) ? trim($_POST['admin_notes']) : 'No reason provided';
    
    $old_stmt = $conn->prepare("SELECT status, user_id FROM reports WHERE id = :id");
    $old_stmt->execute([':id' => $report_id]);
    $report_info = $old_stmt->fetch();
    
    $upd_stmt = $conn->prepare("UPDATE reports SET status = 'rejected', admin_notes = :notes WHERE id = :id");
    $upd_stmt->execute([':notes' => "REJECTED: " . $rejection_notes, ':id' => $report_id]);
    
    $log_stmt = $conn->prepare("
        INSERT INTO admin_logs (admin_id, report_id, action, old_status, new_status, notes)
        VALUES (:admin_id, :report_id, 'rejected', :old_status, 'rejected', :notes)
    ");
    $log_stmt->execute([
        ':admin_id' => $admin_id,
        ':report_id' => $report_id,
        ':old_status' => $report_info['status'],
        ':notes' => 'Rejected: ' . $rejection_notes
    ]);
    
    $notif_stmt = $conn->prepare("
        INSERT INTO notifications (user_id, report_id, type, title, message)
