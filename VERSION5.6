// Start session with enhanced security
ini_set('session.cookie_httponly', 1);
ini_set('session.use_only_cookies', 1);
ini_set('session.cookie_secure', 0); // Set to 1 if using HTTPS

session_start();

// Regenerate session ID on each page load to prevent session fixation
if (!isset($_SESSION['initiated'])) {
    session_regenerate_id(true);
    $_SESSION['initiated'] = true;
}

$host   = "localhost";
$dbname = "pollution_app";
$user   = "root";
$pass   = "";

try {
    $conn = new PDO("mysql:host=$host;dbname=$dbname;charset=utf8", $user, $pass);
    $conn->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    $conn->setAttribute(PDO::ATTR_DEFAULT_FETCH_MODE, PDO::FETCH_ASSOC);
} catch (PDOException $e) {
    die("Connection failed: " . $e->getMessage());
}

// ---- Security Helper Functions ----

function isLoggedIn() {
    return isset($_SESSION['user_id']) && 
           isset($_SESSION['user_agent']) && 
           isset($_SESSION['user_ip']) &&
           isset($_SESSION['login_token']) &&
           validateSession();
}

function validateSession() {
    // Validate user agent hasn't changed (prevents session hijacking)
    if (!isset($_SESSION['user_agent']) || $_SESSION['user_agent'] !== $_SERVER['HTTP_USER_AGENT']) {
        destroySession();
        return false;
    }
    
    // Validate IP hasn't changed (prevents session hijacking from different location)
    if (!isset($_SESSION['user_ip']) || $_SESSION['user_ip'] !== $_SERVER['REMOTE_ADDR']) {
        destroySession();
        return false;
    }
    
    // Validate login token exists and matches
    if (!isset($_SESSION['login_token']) || !isset($_SESSION['login_token_time'])) {
        destroySession();
        return false;
    }
    
    // Check if session has expired (30 minutes of inactivity)
    if (isset($_SESSION['last_activity']) && (time() - $_SESSION['last_activity'] > 1800)) {
        destroySession();
        return false;
    }
    
    // Update last activity time
    $_SESSION['last_activity'] = time();
    
    return true;
}

function destroySession() {
    $_SESSION = array();
    if (isset($_COOKIE[session_name()])) {
        setcookie(session_name(), '', time() - 3600, '/');
    }
    session_destroy();
}

function isAdmin() {
    return isLoggedIn() && isset($_SESSION['role']) && $_SESSION['role'] === 'admin';
}

function redirectIfNotLoggedIn() {
    if (!isLoggedIn()) {
        header("Location: login.php?error=session_expired");
        exit();
    }
}

function redirectIfNotAdmin() {
    if (!isLoggedIn()) {
        header("Location: login.php?error=session_expired");
        exit();
    }
    if (!isAdmin()) {
        header("Location: userDashboard.php");
        exit();
    }
}

// Prevent access to authenticated pages if already logged in
function redirectIfLoggedIn() {
    if (isLoggedIn()) {
        if (isAdmin()) {
            header("Location: adminDashboard.php");
        } else {
            header("Location: userDashboard.php");
        }
        exit();
    }
}

// Generate a unique login token
function generateLoginToken() {
    return bin2hex(random_bytes(32));
}
