CREATE DATABASE IF NOT EXISTS pollution_app;
USE pollution_app;

-- Users table
CREATE TABLE IF NOT EXISTS users (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    username    VARCHAR(50)  NOT NULL UNIQUE,
    email       VARCHAR(100) NOT NULL UNIQUE,
    password    VARCHAR(255) NOT NULL,
    role        ENUM('user','admin') DEFAULT 'user',
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Reports table (UPDATED with all fields from PDF)
CREATE TABLE IF NOT EXISTS reports (
    id               INT AUTO_INCREMENT PRIMARY KEY,
    user_id          INT NOT NULL,
    title            VARCHAR(150) NOT NULL,
    pollution_type   ENUM('Air','Water','Noise','Waste','Chemical','Soil','Other') NOT NULL,
    severity_level   ENUM('Low','Medium','High') NOT NULL,
    description      TEXT,
    photo            VARCHAR(255),
    latitude         DECIMAL(10,7),
    longitude        DECIMAL(10,7),
    location         VARCHAR(200),
    status           ENUM('pending','under_investigation','action_taken','resolved','rejected','approved') DEFAULT 'pending',
    admin_notes      TEXT,
    is_verified      TINYINT(1) DEFAULT 0,
    verified_at      TIMESTAMP NULL,
    verified_by      INT NULL,
    support_count    INT DEFAULT 0,
    created_at       TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (verified_by) REFERENCES users(id) ON DELETE SET NULL
);

-- Community Support/Upvote table
CREATE TABLE IF NOT EXISTS report_supports (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    report_id   INT NOT NULL,
    user_id     INT NOT NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY unique_support (report_id, user_id),
    FOREIGN KEY (report_id) REFERENCES reports(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Forum posts table
CREATE TABLE IF NOT EXISTS posts (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    user_id     INT NOT NULL,
    content     TEXT NOT NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Admin activity logs
CREATE TABLE IF NOT EXISTS admin_logs (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    admin_id    INT NOT NULL,
    report_id   INT NULL,
    action      VARCHAR(100) NOT NULL,
    old_status  VARCHAR(50) NULL,
    new_status  VARCHAR(50) NULL,
    notes       TEXT,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (admin_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (report_id) REFERENCES reports(id) ON DELETE CASCADE
);

-- Validation checklist
CREATE TABLE IF NOT EXISTS validation_checklist (
    id                      INT AUTO_INCREMENT PRIMARY KEY,
    report_id               INT NOT NULL,
    admin_id                INT NOT NULL,
    photo_attached          TINYINT(1) DEFAULT 0,
    location_valid          TINYINT(1) DEFAULT 0,
    description_adequate    TINYINT(1) DEFAULT 0,
    severity_appropriate    TINYINT(1) DEFAULT 0,
    no_duplicates           TINYINT(1) DEFAULT 0,
    overall_valid           TINYINT(1) DEFAULT 0,
    validation_notes        TEXT,
    created_at              TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (report_id) REFERENCES reports(id) ON DELETE CASCADE,
    FOREIGN KEY (admin_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Notifications table
CREATE TABLE IF NOT EXISTS notifications (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    user_id     INT NOT NULL,
    report_id   INT NULL,
    type        ENUM('new_report','status_update','admin_action','support_received','high_severity_alert') NOT NULL,
    title       VARCHAR(200) NOT NULL,
    message     TEXT NOT NULL,
    is_read     TINYINT(1) DEFAULT 0,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (report_id) REFERENCES reports(id) ON DELETE CASCADE
);

