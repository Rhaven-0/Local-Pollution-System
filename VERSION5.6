// Filter Functions: My Reports
// =============================================
function applyMyReportsFilters() {
    const type = document.getElementById('my-filter-type').value;
    const severity = document.getElementById('my-filter-severity').value;
    const date = document.getElementById('my-filter-date').value;
    const location = document.getElementById('my-filter-location').value;
    
    console.log('My Reports Filters:', {type, severity, date, location});
    
    const params = new URLSearchParams({
        scope: 'my_reports',
        per_page: 100,
        page: 1
    });
    
    if (type) params.append('type', type);
    if (severity) params.append('severity', severity);
    if (date) {
        params.append('date_from', date);
        params.append('date_to', date);
    }
    if (location) params.append('location', location);
    
    const url = 'search.php?' + params.toString();
    console.log('Fetching:', url);
    
    fetch(url)
        .then(res => res.json())
        .then(data => {
            console.log('My Reports Response:', data);
            if (data.success) {
                renderMyReports(data.reports);
            } else {
                console.error('Error:', data.error);
            }
        })
        .catch(err => console.error('Filter error:', err));
}

function clearMyReportsFilters() {
    document.getElementById('my-filter-type').value = '';
    document.getElementById('my-filter-severity').value = '';
    document.getElementById('my-filter-date').value = '';
    document.getElementById('my-filter-location').value = '';
    
    fetch('search.php?scope=my_reports&per_page=100&page=1')
        .then(res => res.json())
        .then(data => {
            console.log('Clear filters response:', data);
            if (data.success) {
                renderMyReports(data.reports);
            }
        });
}

function renderMyReports(reports) {
    const tbody = document.getElementById('my-reports-tbody');
    
    console.log('Rendering', reports.length, 'reports');
    
    if (reports.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted" style="padding:16px;">No reports found.</td></tr>';
        return;
    }
    
    let html = '';
    reports.forEach(r => {
        html += `
        <tr>
            <td>${escapeHtml(r.title)}</td>
            <td>${r.pollution_type}</td>
            <td>${r.severity_level}</td>
            <td>${escapeHtml(r.location || '—')}</td>
            <td><span class="badge badge-${r.status}">${r.status.replace(/_/g, ' ')}</span></td>
            <td>${new Date(r.created_at).toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'})}</td>
        </tr>`;
    });
    
    tbody.innerHTML = html;
}

