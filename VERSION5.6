    ");
    $notif_stmt->execute([
        ':uid' => $report_info['user_id'],
        ':rid' => $report_id,
        ':msg' => 'Your report was rejected. Reason: ' . $rejection_notes
    ]);
    
    header("Location: adminDashboard.php");
    exit();
}

// Handle status updates (workflow only)
if (isset($_POST['update_status'])) {
    $report_id = (int) $_POST['report_id'];
    $new_status = trim($_POST['new_status']);
    $admin_notes = isset($_POST['admin_notes']) ? trim($_POST['admin_notes']) : '';
    $admin_id = $_SESSION['user_id'];
    
    $valid_statuses = ['pending', 'under_investigation', 'action_taken', 'resolved', 'approved', 'rejected'];
    
    if (in_array($new_status, $valid_statuses)) {
        $old_stmt = $conn->prepare("SELECT status, user_id FROM reports WHERE id = :id");
        $old_stmt->execute([':id' => $report_id]);
        $report_info = $old_stmt->fetch();
        $old_status = $report_info['status'];
        
        $stmt = $conn->prepare("UPDATE reports SET status = :status, admin_notes = :notes WHERE id = :id");
        $stmt->execute([':status' => $new_status, ':notes' => $admin_notes, ':id' => $report_id]);
        
        $log_stmt = $conn->prepare("
            INSERT INTO admin_logs (admin_id, report_id, action, old_status, new_status, notes)
            VALUES (:admin_id, :report_id, 'status_updated', :old_status, :new_status, :notes)
        ");
        $log_stmt->execute([
            ':admin_id' => $admin_id,
            ':report_id' => $report_id,
            ':old_status' => $old_status,
            ':new_status' => $new_status,
            ':notes' => $admin_notes
        ]);
        
        $notif_stmt = $conn->prepare("
            INSERT INTO notifications (user_id, report_id, type, title, message)
            VALUES (:uid, :rid, 'status_update', 'Report Status Updated', CONCAT('Your report status changed to: ', :status))
        ");
        $notif_stmt->execute([
            ':uid' => $report_info['user_id'],
            ':rid' => $report_id,
            ':status' => ucfirst(str_replace('_', ' ', $new_status))
        ]);
        
        header("Location: adminDashboard.php");
        exit();
    }
}

