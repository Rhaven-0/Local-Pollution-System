<script>
// =============================================
// AJAX Live Updates (Only Pending Reports)
// =============================================
let countdown = 30;
let refreshTimer;
let countdownTimer;

function startAutoRefresh() {
    refreshTimer = setInterval(refreshDashboard, 30000);
    countdownTimer = setInterval(() => {
        countdown--;
        document.getElementById('refresh-countdown').textContent = countdown;
        if (countdown <= 0) countdown = 30;
    }, 1000);
}

function refreshDashboard() {
    fetch('admin_dashboard_data.php')
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                document.getElementById('stat-total').textContent = data.stats.total;
                document.getElementById('stat-pending').textContent = data.stats.pending;
                document.getElementById('stat-investigating').textContent = data.stats.investigating;
                document.getElementById('stat-resolved').textContent = data.stats.resolved;
                updateLiveReports(data.recent_reports);
                document.getElementById('last-update-time').textContent = 'just now';
                countdown = 30;
            }
        })
        .catch(err => console.error('Auto-refresh failed:', err));
}

function updateLiveReports(reports) {
    const tbody = document.getElementById('live-reports-body');
    
    if (reports.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No pending reports.</td></tr>';
        return;
    }
    
    const existingIds = Array.from(tbody.querySelectorAll('tr')).map(tr => tr.dataset.reportId);
    
    let html = '';
    reports.forEach(r => {
        const isNew = !existingIds.includes(r.id.toString());
        const severityColor = r.severity_level === 'High' ? '#c0392b' : (r.severity_level === 'Medium' ? '#e0a800' : '#28a745');
        
        html += `
        <tr data-report-id="${r.id}" class="${isNew ? 'new-report-flash' : ''}">
            <td>${new Date(r.created_at).toLocaleTimeString('en-US', {hour: 'numeric', minute: '2-digit'})}</td>
            <td>${escapeHtml(r.title)}</td>
            <td>${r.pollution_type}</td>
            <td><span style="color:${severityColor}">${r.severity_level}</span></td>
            <td>${escapeHtml(r.username)}</td>
            <td><button class="btn btn-sm btn-primary" onclick='openReviewModal(${r.id}, ${JSON.stringify(r)})'>Review</button></td>
        </tr>`;
    });
    
    tbody.innerHTML = html;
}

window.addEventListener('load', startAutoRefresh);

// =============================================
// Admin Filter & Pagination
// =============================================
let adminCurrentPage = 1;
let adminAllReports = [];

// Store all reports on page load
<?php if (!empty($reports)): ?>
adminAllReports = <?php echo json_encode($reports); ?>;
<?php endif; ?>

function applyAdminFilters() {
    const type = document.getElementById('filter-type').value;
    const severity = document.getElementById('filter-severity').value;
    const date = document.getElementById('filter-date').value;
    const location = document.getElementById('filter-location').value;
    
    console.log('Admin Filters:', {type, severity, date, location});
    
    const params = new URLSearchParams({
        scope: 'admin_all',
        per_page: 5,
        page: 1
    });
    
    if (type) params.append('type', type);
    if (severity) params.append('severity', severity);
    if (date) {
        params.append('date_from', date);
        params.append('date_to', date);
    }
    if (location) params.append('location', location);
    
    const url = 'search.php?' + params.toString();
    console.log('Fetching:', url);
    
    fetch(url)
        .then(res => res.json())
        .then(data => {
            console.log('Admin Response:', data);
            if (data.success) {
                adminAllReports = data.reports;
                adminCurrentPage = 1;
                renderAdminReports();
                renderAdminPagination(data.pagination.total_pages);
            } else {
                console.error('Error:', data.error);
            }
        })
        .catch(err => console.error('Filter error:', err));
}

function clearAdminFilters() {
    document.getElementById('filter-type').value = '';
    document.getElementById('filter-severity').value = '';
    document.getElementById('filter-date').value = '';
    document.getElementById('filter-location').value = '';
    
    fetch('search.php?scope=admin_all&per_page=100&page=1')
        .then(res => res.json())
        .then(data => {
            console.log('Clear admin filters response:', data);
            if (data.success) {
                adminAllReports = data.reports;
                adminCurrentPage = 1;
                renderAdminReports();
                renderAdminPagination(Math.ceil(adminAllReports.length / 5));
            }
        });
}

function renderAdminReports() {
    const tbody = document.getElementById('admin-reports-tbody');
    const start = (adminCurrentPage - 1) * 5;
    const end = start + 5;
    const pageReports = adminAllReports.slice(start, end);
    
    if (pageReports.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted">No reports found.</td></tr>';
        return;
    }
    
    let html = '';
    pageReports.forEach(r => {
        const photoHTML = r.photo 
            ? `<img src="uploads/${escapeHtml(r.photo)}" class="photo-thumb" alt="photo">`
            : '<span class="text-muted">None</span>';
        
        html += `
        <tr>
            <td>${photoHTML}</td>
            <td>${escapeHtml(r.title)}</td>
            <td>${r.pollution_type}</td>
            <td>${r.severity_level}</td>
            <td>${escapeHtml(r.username)}</td>
            <td>${escapeHtml(r.location || '—')}</td>
            <td>${new Date(r.created_at).toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'})}</td>
            <td><span class="badge badge-${r.status}">${r.status.replace(/_/g, ' ')}</span></td>
            <td>
                <button class="btn btn-sm btn-primary" onclick='openViewModal(${JSON.stringify(r)})'>View</button>
                <button class="btn btn-sm btn-warning" onclick='openStatusModal(${r.id}, "${r.status}", "${escapeHtml(r.admin_notes || '')}")'>Update</button>
                <a href="adminDashboard.php?delete_report=${r.id}" class="btn btn-sm btn-danger" onclick="return confirm('Delete permanently?');">Delete</a>
            </td>
        </tr>`;
    });
    
    tbody.innerHTML = html;
    document.getElementById('admin-current-page').textContent = adminCurrentPage;
}

function renderAdminPagination(totalPages) {
    const container = document.getElementById('admin-pagination');
    
    if (totalPages <= 1) {
        container.innerHTML = '';
        return;
    }
    
    let html = '<div style="display: inline-flex; gap: 4px;">';
    for (let i = 1; i <= totalPages; i++) {
        const btnClass = i === adminCurrentPage ? 'btn-primary' : 'btn-secondary';
        html += `<button class="btn btn-sm ${btnClass}" onclick="goToAdminPage(${i})" id="admin-page-${i}">${i}</button>`;
    }
    html += '</div>';
    html += `<div style="margin-top: 8px; font-size: 0.85rem; color: #666;">Page <span id="admin-current-page">${adminCurrentPage}</span> of <span id="admin-total-pages">${totalPages}</span></div>`;
    
    container.innerHTML = html;
}

function goToAdminPage(page) {
    adminCurrentPage = page;
    renderAdminReports();
    
    // Update button styles
    const totalPages = Math.ceil(adminAllReports.length / 5);
    for (let i = 1; i <= totalPages; i++) {
        const btn = document.getElementById('admin-page-' + i);
        if (btn) {
            btn.className = i === page ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-secondary';
        }
    }
    
    document.getElementById('admin-current-page').textContent = page;
}

// =============================================
// Tab Switching
// =============================================
function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}

// =============================================
// Modal Functions
// =============================================
let currentReportId = null;

function openStatusModal(reportId, currentStatus, adminNotes) {
    document.getElementById('report_id').value = reportId;
    document.getElementById('new_status').value = currentStatus;
    document.getElementById('admin_notes').value = adminNotes;
    document.getElementById('status-modal').style.display = 'flex';
}

function closeStatusModal() {
    document.getElementById('status-modal').style.display = 'none';
}

// Review Modal (Live Feed)
function openReviewModal(reportId, reportData) {
    currentReportId = reportId;
    const modal = document.getElementById('review-modal');
    const content = document.getElementById('review-content');
    
    const severityColor = reportData.severity_level === 'High' ? '#c0392b' : (reportData.severity_level === 'Medium' ? '#e0a800' : '#28a745');
    
    let photoHTML = reportData.photo ? `<div style="margin: 12px 0;"><img src="uploads/${escapeHtml(reportData.photo)}" style="max-width: 100%; max-height: 300px; border-radius: 6px;"></div>` : '';
    let descHTML = reportData.description ? `<div style="margin: 12px 0;"><strong>Description:</strong><p>${escapeHtml(reportData.description).replace(/\n/g, '<br>')}</p></div>` : '';
    
    content.innerHTML = `
        <div style="border-bottom: 1px solid #ddd; padding-bottom: 12px; margin-bottom: 12px;">
            <h3 style="margin: 0 0 8px 0;">${escapeHtml(reportData.title)}</h3>
            <div style="color: #666; font-size: 0.9rem;">
                <div>📅 ${new Date(reportData.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</div>
                <div>👤 By: <strong>${escapeHtml(reportData.username)}</strong></div>
            </div>
        </div>
        
        <div style="margin-bottom: 12px;">
            <span style="display: inline-block; margin-right: 12px;"><strong>Type:</strong> ${escapeHtml(reportData.pollution_type)}</span>
            <span style="display: inline-block; color:${severityColor};"><strong>Severity:</strong> ${escapeHtml(reportData.severity_level)}</span>
        </div>
        
        <div style="margin-bottom: 12px;">
            <strong>📍 Location:</strong> ${escapeHtml(reportData.location || 'Not specified')}
        </div>
        
        ${photoHTML}
        ${descHTML}
    `;
    
    document.getElementById('review-notes').value = '';
    modal.style.display = 'flex';
}

function closeReviewModal() {
    document.getElementById('review-modal').style.display = 'none';
    currentReportId = null;
}

// Approve Report
function approveReport() {
    if (!currentReportId) return;
    
    const notes = document.getElementById('review-notes').value.trim();
    
    const form = document.createElement('form');
    form.method = 'POST';
    form.innerHTML = `
        <input type="hidden" name="report_id" value="${currentReportId}">
        <input type="hidden" name="admin_notes" value="${notes}">
        <input type="hidden" name="approve_report" value="1">
    `;
    document.body.appendChild(form);
    form.submit();
}

// Reject Report
function rejectReport() {
    if (!currentReportId) return;
    
    const notes = document.getElementById('review-notes').value.trim();
    
    if (!notes) {
        alert('Please provide a reason for rejection in the remarks field.');
        return;
    }
    
    const form = document.createElement('form');
    form.method = 'POST';
    form.innerHTML = `
        <input type="hidden" name="report_id" value="${currentReportId}">
        <input type="hidden" name="admin_notes" value="${notes}">
        <input type="hidden" name="reject_report" value="1">
    `;
    document.body.appendChild(form);
    form.submit();
}

// View Modal (All Reports Tab - Read Only)
function openViewModal(reportData) {
    const modal = document.getElementById('view-modal');
    const content = document.getElementById('view-content');
    
    const severityColor = reportData.severity_level === 'High' ? '#c0392b' : (reportData.severity_level === 'Medium' ? '#e0a800' : '#28a745');
    
    let photoHTML = reportData.photo ? `<div style="margin: 12px 0;"><img src="uploads/${escapeHtml(reportData.photo)}" style="max-width: 100%; max-height: 300px; border-radius: 6px;"></div>` : '';
    let descHTML = reportData.description ? `<div style="margin: 12px 0;"><strong>Description:</strong><p>${escapeHtml(reportData.description).replace(/\n/g, '<br>')}</p></div>` : '';
    
    content.innerHTML = `
        <div style="border-bottom: 1px solid #ddd; padding-bottom: 12px; margin-bottom: 12px;">
            <h3 style="margin: 0 0 8px 0;">${escapeHtml(reportData.title)}</h3>
            <div style="color: #666; font-size: 0.9rem;">
                <div>📅 ${new Date(reportData.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</div>
                <div>👤 By: <strong>${escapeHtml(reportData.username)}</strong></div>
            </div>
        </div>
        
        <div style="margin-bottom: 12px;">
            <span style="display: inline-block; margin-right: 12px;"><strong>Type:</strong> ${escapeHtml(reportData.pollution_type)}</span>
            <span style="display: inline-block; color:${severityColor};"><strong>Severity:</strong> ${escapeHtml(reportData.severity_level)}</span>
        </div>
        
        <div style="margin-bottom: 12px;">
            <strong>📍 Location:</strong> ${escapeHtml(reportData.location || 'Not specified')}
        </div>
        
        <div style="margin-bottom: 12px;">
            <strong>Status:</strong> <span class="badge badge-${reportData.status}">${reportData.status.replace(/_/g, ' ')}</span>
        </div>
        
        ${photoHTML}
        ${descHTML}
        
        <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid #ddd;">
            <strong>📝 Admin Notes:</strong>
            <p>${reportData.admin_notes ? escapeHtml(reportData.admin_notes).replace(/\n/g, '<br>') : '<em style="color: #999;">None yet</em>'}</p>
        </div>
    `;
    
    modal.style.display = 'flex';
}

function closeViewModal() {
    document.getElementById('view-modal').style.display = 'none';
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

window.onclick = function(event) {
    if (event.target.classList.contains('modal')) {
        event.target.style.display = 'none';
    }
}
</script>
</body>
</html>
