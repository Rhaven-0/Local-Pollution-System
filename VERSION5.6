header('Content-Type: application/json');

try {
    $user_id = $_SESSION['user_id'];
    $is_admin = $_SESSION['role'] === 'admin';

    // Get filter parameters
    $type = isset($_GET['type']) && $_GET['type'] !== '' ? trim($_GET['type']) : '';
    $severity = isset($_GET['severity']) && $_GET['severity'] !== '' ? trim($_GET['severity']) : '';
    $date_from = isset($_GET['date_from']) && $_GET['date_from'] !== '' ? trim($_GET['date_from']) : '';
    $date_to = isset($_GET['date_to']) && $_GET['date_to'] !== '' ? trim($_GET['date_to']) : '';
    $location = isset($_GET['location']) && $_GET['location'] !== '' ? trim($_GET['location']) : '';
    $search = isset($_GET['search']) && $_GET['search'] !== '' ? trim($_GET['search']) : '';
    $scope = isset($_GET['scope']) ? trim($_GET['scope']) : 'all'; // all, my_reports, community_feed, admin_all

    // Pagination
    $page = isset($_GET['page']) ? max(1, (int)$_GET['page']) : 1;
    $per_page = isset($_GET['per_page']) ? (int)$_GET['per_page'] : 10;
    $offset = ($page - 1) * $per_page;

    // Build query based on scope
    $conditions = [];
    $params = [];

    // Scope-based base condition
    if ($scope === 'my_reports') {
        $conditions[] = "r.user_id = :user_id";
        $params[':user_id'] = $user_id;
    } elseif ($scope === 'community_feed') {
        $conditions[] = "r.status = 'approved'";
        $conditions[] = "r.is_verified = 1";
    } elseif ($scope === 'admin_all') {
        if (!$is_admin) {
            echo json_encode(['success' => false, 'error' => 'Unauthorized']);
            exit();
        }
        $conditions[] = "r.status IN ('approved', 'rejected', 'under_investigation', 'action_taken', 'resolved')";
    }

    // Type filter
    if ($type) {
        $conditions[] = "r.pollution_type = :type";
        $params[':type'] = $type;
    }

    // Severity filter
    if ($severity) {
        $conditions[] = "r.severity_level = :severity";
        $params[':severity'] = $severity;
    }

    // Date range
    if ($date_from) {
        $conditions[] = "DATE(r.created_at) >= :date_from";
        $params[':date_from'] = $date_from;
    }
    if ($date_to) {
        $conditions[] = "DATE(r.created_at) <= :date_to";
        $params[':date_to'] = $date_to;
    }

    // Location filter
    if ($location) {
        $conditions[] = "r.location LIKE :location";
        $params[':location'] = '%' . $location . '%';
    }

    // Search (title or description)
    if ($search) {
        $conditions[] = "(r.title LIKE :search OR r.description LIKE :search)";
        $params[':search'] = '%' . $search . '%';
    }

    // Build WHERE clause
    $where = count($conditions) > 0 ? 'WHERE ' . implode(' AND ', $conditions) : '';

    // Get total count
    $count_query = "SELECT COUNT(*) FROM reports r $where";
    $count_stmt = $conn->prepare($count_query);
    $count_stmt->execute($params);
    $total_records = $count_stmt->fetchColumn();
    $total_pages = ceil($total_records / $per_page);

    // Get filtered reports
    $query = "
        SELECT r.*, u.username,
               (SELECT COUNT(*) FROM report_supports WHERE report_id = r.id) as support_count,
               (SELECT COUNT(*) FROM report_supports WHERE report_id = r.id AND user_id = :current_user_id) as user_supported
        FROM reports r
        JOIN users u ON r.user_id = u.id
        $where
        ORDER BY r.created_at DESC
        LIMIT :limit OFFSET :offset
    ";

    $stmt = $conn->prepare($query);
    foreach ($params as $key => $value) {
        $stmt->bindValue($key, $value);
    }
    $stmt->bindValue(':current_user_id', $user_id, PDO::PARAM_INT);
    $stmt->bindValue(':limit', $per_page, PDO::PARAM_INT);
    $stmt->bindValue(':offset', $offset, PDO::PARAM_INT);
    $stmt->execute();
    $reports = $stmt->fetchAll();

    echo json_encode([
        'success' => true,
        'reports' => $reports,
        'pagination' => [
            'current_page' => $page,
            'total_pages' => $total_pages,
            'total_records' => (int)$total_records,
            'per_page' => $per_page
        ]
    ]);
} catch (Exception $e) {
    error_log("Search error: " . $e->getMessage());
    echo json_encode([
        'success' => false,
        'error' => 'Database error',
        'message' => $e->getMessage()
    ]);
}
