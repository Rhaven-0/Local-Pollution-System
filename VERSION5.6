            $stmt   = $conn->prepare("INSERT INTO users (username, email, password) VALUES (:u, :e, :p)");
            $stmt->execute([':u' => $username, ':e' => $email, ':p' => $hashed]);
            $success = "Account created! You can now <a href='login.php'>log in</a>.";
        }
    }
